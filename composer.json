{
    "name": "yiisoft/demo-diary",
    "type": "project",
    "description": "Yii3 Demo Diary Application",
    "license": "BSD-3-Clause",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require": {
        "php": "^8.1"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.0",
        "rector/rector": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "scripts": {
        "post-install-cmd": [
            "echo 'Post-install complete.'"
        ],
        "cs-fix": "./vendor/bin/php-cs-fixer fix --config=.php-cs-fixer.php"
    },
    "config": {
        "allow-plugins": {
            "composer/installers": true
        }
    }
}
